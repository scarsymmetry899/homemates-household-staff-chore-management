# Telegram Bot
VITE_TELEGRAM_BOT_TOKEN=your_bot_token_here
# Owner's personal Telegram Chat ID (for NFC check-in notifications)
# Get it by messaging @userinfobot on Telegram
VITE_OWNER_TELEGRAM_CHAT_ID=

# Firebase Client SDK
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google Sheets Webhook (Apps Script deployment URL)
VITE_GOOGLE_SHEETS_WEBHOOK_URL=
